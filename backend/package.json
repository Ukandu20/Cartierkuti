{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend server for Cartierkuti Portfolio",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon -r dotenv/config src/server.js",
    "start": "node -r dotenv/config src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node --check src/server.js && node --check src/app.js",
    "seed:dev": "node -r dotenv/config scripts/dynamicseeder.js",
    "seed:prod": "node -r dotenv/config scripts/seeder.js"
  },
  "keywords": [
    "portfolio",
    "backend",
    "nodejs",
    "express",
    "mongoose"
  ],
  "author": "Okechi Ukandu",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.0.0",
    "mongoose": "^8.12.1",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.13",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "vitest": "^3.0.8"
  }
}
